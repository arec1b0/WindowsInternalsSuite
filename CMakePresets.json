{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "WIS_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "vs2022",
      "displayName": "Visual Studio 2022 (x64)",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" }
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug (x64)",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release (x64)",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    { "name": "vs2022-debug",   "configurePreset": "vs2022",        "configuration": "Debug" },
    { "name": "vs2022-release", "configurePreset": "vs2022",        "configuration": "Release" },
    { "name": "ninja-debug",    "configurePreset": "ninja-debug" },
    { "name": "ninja-release",  "configurePreset": "ninja-release" }
  ],
  "testPresets": [
    {
      "name": "vs2022-debug",
      "configurePreset": "vs2022",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "ninja-debug",
      "configurePreset": "ninja-debug",
      "output": { "outputOnFailure": true }
    }
  ]
}